{
  "name": "TidePebble",
  "author": "ModusApps",
  "version": "0.1.0",
  "keywords": ["pebble-app"],
  "private": true,
  "dependencies": {},
  "pebble": {
    "displayName": "TidePebble",
    "uuid": "36fecabf-c78d-4ffb-a892-081d60796638",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "emery"
    ],
    "watchapp": {
      "watchface": false,
      "configurable": true
    },
    "messageKeys": [
      "tide_location",
      "tide_status",
      "tide_current_minutes",
      "tide_sample_offset",
      "tide_values",
      "tide_times",
      "tide_wave_height",
      "tide_sea_temp",
      "tide_wave_values"
    ],
    "capabilities": ["configurable", "location"],
    "resources": {
      "media": [
        {
          "type": "png",
          "name": "IMAGE_MENU_ICON",
          "file": "images/menu_icon.png",
          "menuIcon": true
        }
      ]
    }
  }
}
